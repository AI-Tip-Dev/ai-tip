{
  "name": "@ai-tip/sdk",
  "version": "0.1.0",
  "description": "AI Tip JS SDK — one import to call native desktop/browser capabilities from any SaaS page",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:iife": "npx tsx scripts/build-iife.ts",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "keywords": [
    "ai-tip",
    "sdk",
    "electron",
    "browser-extension",
    "bridge",
    "native",
    "desktop"
  ],
  "license": "MIT",
  "author": "AI Tip Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-tip/sdk"
  },
  "dependencies": {},
  "devDependencies": {
    "@ai-tip/form-detection": "workspace:*",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0"
  }
}
